  "keyFeatures": [
    "Privacy-preserving AI endpoints",
    "Multi-database support (Weaviate, Qdrant, ChromaDB)",
    "Multi-model support (OpenAI, Anthropic, Ollama, vLLM)",
    "Automatic Docker provisioning for vector databases",
    "Desktop and web interface with Tauri",
    "RAG (Retrieval-Augmented Generation) capabilities",
    "Access control and rate limiting policies",
    "SyftHub marketplace integration",
    "Document ingestion and indexing",
    "Usage analytics and cost tracking"
  ],
  "publicApiSurface": [
    "POST /api/v1/endpoints/ - Create endpoint",
    "POST /api/v1/endpoints/{slug}/query - Query endpoint",
    "POST /api/v1/endpoints/{id}/publish - Publish endpoint",
    "GET /api/v1/endpoints/ - List endpoints",
    "POST /api/v1/datasets/ - Create dataset",
    "GET /api/v1/datasets/ - List datasets",
    "GET /api/v1/datasets/types/ - List dataset types",
    "POST /api/v1/models/ - Create model",
    "GET /api/v1/models/ - List models",
    "GET /api/v1/models/types/ - List model types",
    "POST /api/v1/policies/ - Create policy",
    "GET /api/v1/policies/ - List policies",
    "GET /api/v1/policies/types/ - List policy types",
    "GET /api/v1/settings/ - Get settings",
    "PUT /api/v1/settings/ - Update settings"
  ]
